<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lumina.controller.DetalleProfesorController"
      styleClass="root-container"
      stylesheets="@profesor_styles.css">

    <!-- ═══════════════════════════════════════ SIDEBAR ═══════════════════════════════════════ -->
    <VBox styleClass="sidebar" minWidth="256" maxWidth="256">

        <!-- Logo / Brand -->
        <HBox styleClass="sidebar-brand" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="brand-icon-wrapper">
                <SVGPath styleClass="brand-icon-svg"
                         content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"
                         scaleX="0.85" scaleY="0.85"/>
            </StackPane>
            <VBox spacing="1">
                <Label styleClass="brand-name" text="Lumina Academy"/>
                <Label styleClass="brand-sub" text="ADMIN PORTAL"/>
            </VBox>
        </HBox>

        <!-- Navigation -->
        <VBox styleClass="nav-list" VBox.vgrow="ALWAYS" spacing="4">
            <Insets top="24" left="16" right="16" bottom="16"/>

            <!-- Inicio -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                <Label text="Inicio" styleClass="nav-label"/>
            </HBox>

            <!-- Estudiantes -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
                <Label text="Estudiantes" styleClass="nav-label"/>
            </HBox>

            <!-- Cursos -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1z"/>
                <Label text="Cursos" styleClass="nav-label"/>
            </HBox>

            <!-- Profesores (activo) -->
            <HBox styleClass="nav-item nav-item-active" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon nav-icon-active"
                         content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                <Label text="Profesores" styleClass="nav-label nav-label-active"/>
            </HBox>

            <!-- Horario -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                <Label text="Horario" styleClass="nav-label"/>
            </HBox>

            <!-- Configuración -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                <Label text="Configuración" styleClass="nav-label"/>
            </HBox>

        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════ MAIN AREA ═══════════════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS" styleClass="main-area">

        <!-- Header -->
        <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="24">

            <!-- Search -->
            <StackPane HBox.hgrow="ALWAYS" maxWidth="560" styleClass="search-wrapper">
                <SVGPath styleClass="search-icon"
                         content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                         StackPane.alignment="CENTER_LEFT" translateX="14"/>
                <TextField fx:id="searchField"
                           styleClass="search-field"
                           promptText="Buscar expedientes, cursos o reportes..."/>
            </StackPane>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Notification Bell -->
            <StackPane styleClass="icon-btn">
                <SVGPath styleClass="header-icon"
                         content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
                <Circle styleClass="notif-dot" radius="4" translateX="7" translateY="-7"/>
            </StackPane>

            <!-- Help -->
            <StackPane styleClass="icon-btn">
                <SVGPath styleClass="header-icon"
                         content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
            </StackPane>

            <!-- Admin Profile -->
            <HBox alignment="CENTER" spacing="12" styleClass="admin-profile">
                <StackPane styleClass="admin-avatar">
                    <SVGPath styleClass="admin-avatar-icon"
                             content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </StackPane>
                <VBox spacing="1">
                    <Label styleClass="admin-name" text="Admin User"/>
                    <Label styleClass="admin-email" text="admin@lumina.edu"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- Scrollable Content -->
        <ScrollPane styleClass="content-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">

            <VBox styleClass="content-inner" spacing="24">
                <Insets top="32" left="32" right="32" bottom="32"/>

                <!-- Back Link -->
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="back-link" onMouseClicked="#handleBack">
                    <SVGPath styleClass="back-icon"
                             content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                    <Label text="Volver al listado" styleClass="back-label"/>
                </HBox>

                <!-- ─── Profile Card ─── -->
                <HBox styleClass="card profile-card" alignment="CENTER_LEFT" spacing="24">

                    <!-- Avatar Container -->
                    <StackPane styleClass="professor-avatar-container" fx:id="avatarContainer">
                        <!-- SVGPath se inyecta dinámicamente desde el Controller -->
                    </StackPane>

                    <VBox spacing="6">
                        <Label fx:id="professorName" styleClass="professor-name" text="Dr. Roberto Sánchez"/>
                        <Label fx:id="professorSubject" styleClass="professor-subject" text="Profesor de Matemáticas y Cálculo"/>
                    </VBox>

                </HBox>

                <!-- ─── Two-Column Grid ─── -->
                <HBox spacing="24">

                    <!-- Cursos y Materias -->
                    <VBox styleClass="card detail-card" HBox.hgrow="ALWAYS" spacing="0">

                        <Label styleClass="card-title" text="Cursos y Materias">
                            <VBox.margin>
                                <Insets bottom="20"/>
                            </VBox.margin>
                        </Label>

                        <VBox fx:id="coursesContainer" spacing="0">

                            <HBox styleClass="course-row course-row-border">
                                <Label styleClass="course-name" text="Matemáticas Avanzadas - 5to E"/>
                            </HBox>

                            <HBox styleClass="course-row course-row-border">
                                <Label styleClass="course-name" text="Cálculo I - 6to A"/>
                            </HBox>

                            <HBox styleClass="course-row">
                                <Label styleClass="course-name" text="Álgebra - 4to B"/>
                            </HBox>

                        </VBox>
                    </VBox>

                    <!-- Horario Detallado -->
                    <VBox styleClass="card detail-card" HBox.hgrow="ALWAYS" spacing="0">

                        <Label styleClass="card-title" text="Horario Detallado">
                            <VBox.margin>
                                <Insets bottom="20"/>
                            </VBox.margin>
                        </Label>

                        <VBox fx:id="scheduleContainer" spacing="0">

                            <!-- Timeline Item 1 (active/blue dot) -->
                            <HBox spacing="16" styleClass="timeline-item">
                                <VBox alignment="TOP_CENTER" spacing="0" minWidth="16" maxWidth="16">
                                    <Circle styleClass="timeline-dot timeline-dot-active" radius="8"/>
                                    <Region styleClass="timeline-line" VBox.vgrow="ALWAYS"/>
                                </VBox>
                                <VBox spacing="4" styleClass="timeline-content">
                                    <Label styleClass="timeline-time" text="09:00 AM - 10:30 AM"/>
                                    <Label styleClass="timeline-class" text="Matemáticas en 5to E"/>
                                </VBox>
                            </HBox>

                            <!-- Timeline Item 2 -->
                            <HBox spacing="16" styleClass="timeline-item">
                                <VBox alignment="TOP_CENTER" spacing="0" minWidth="16" maxWidth="16">
                                    <Circle styleClass="timeline-dot timeline-dot-inactive" radius="8"/>
                                    <Region styleClass="timeline-line" VBox.vgrow="ALWAYS"/>
                                </VBox>
                                <VBox spacing="4" styleClass="timeline-content">
                                    <Label styleClass="timeline-time" text="11:00 AM - 12:30 PM"/>
                                    <Label styleClass="timeline-class" text="Cálculo I en 6to A"/>
                                </VBox>
                            </HBox>

                            <!-- Timeline Item 3 (last, no line) -->
                            <HBox spacing="16" styleClass="timeline-item">
                                <VBox alignment="TOP_CENTER" spacing="0" minWidth="16" maxWidth="16">
                                    <Circle styleClass="timeline-dot timeline-dot-inactive" radius="8"/>
                                </VBox>
                                <VBox spacing="4" styleClass="timeline-content">
                                    <Label styleClass="timeline-time" text="12:30 PM - 01:30 PM"/>
                                    <Label styleClass="timeline-class" text="Álgebra en 4to B"/>
                                </VBox>
                            </HBox>

                        </VBox>
                    </VBox>

                </HBox>

                <!-- ─── Attendance Table ─── -->
                <VBox styleClass="card attendance-card" spacing="0">

                    <Label styleClass="card-title" text="Asistencia del Profesor">
                        <VBox.margin>
                            <Insets bottom="20"/>
                        </VBox.margin>
                    </Label>

                    <TableView fx:id="attendanceTable" styleClass="attendance-table">
                        <columns>
                            <TableColumn fx:id="colFecha"     text="Fecha"        prefWidth="180" styleClass="table-col"/>
                            <TableColumn fx:id="colEntrada"   text="Hora Entrada" prefWidth="180" styleClass="table-col"/>
                            <TableColumn fx:id="colSalida"    text="Hora Salida"  prefWidth="180" styleClass="table-col"/>
                            <TableColumn fx:id="colEstado"    text="Estado"       prefWidth="220" styleClass="table-col"/>
                        </columns>
                        <placeholder>
                            <Label text="Sin registros de asistencia" styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>

                </VBox>

            </VBox>
        </ScrollPane>

    </VBox>
</HBox>
