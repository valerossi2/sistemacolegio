<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.edugrade.controllers.CursoController"
            fx:id="rootPane"
            styleClass="root-pane"
            stylesheets="@../../css/Cursos.css">

    <!-- SIDEBAR -->

    <left>
        <VBox fx:id="sideNavBar" styleClass="side-navbar" prefWidth="256">

            <!-- Logo -->
            <HBox styleClass="side-navbar__brand" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="brand-logo-placeholder">
                    <Label text="L" styleClass="brand-logo-initial"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Lumina Academy"      styleClass="brand-title"/>
                    <Label text="Academic Management" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <!-- Ítems de navegación -->
            <VBox fx:id="navItemsContainer"
                  styleClass="nav-items-container"
                  spacing="2"
                  VBox.vgrow="ALWAYS">

                <!-- icono-logo  -->

                <HBox fx:id="navinicio" styleClass="nav-item"
                      spacing="12" alignment="CENTER_LEFT"
                      onMouseClicked="#onNavinicio">
                    <SVGPath styleClass="nav-svg-icon"
                             content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                             scaleX="0.9" scaleY="0.9"/>
                    <Label text="Inicio" styleClass="nav-item__label"/>
                </HBox>

                <!-- curso-activo  -->
                <HBox fx:id="navCursos" styleClass="nav-item nav-item--active"
                      spacing="12" alignment="CENTER_LEFT"
                      onMouseClicked="#onNavCursos">
                    <SVGPath styleClass="nav-svg-icon nav-svg-icon--active"
                             content="M19 2l-5 4.5v11l5-4.5V2zM6.5 5C4.55 5 2.45 5.4 1 6.5v11.5c1.45-1.1 3.55-1.5 5.5-1.5s4.05.4 5.5 1.5V6.5C14.95 5.4 12.85 5 10.5 5S8.05 5.4 6.5 5z"
                             scaleX="0.9" scaleY="0.9"/>
                    <Label text="Cursos" styleClass="nav-item__label"/>
                </HBox>

                <HBox fx:id="navEstudiantes" styleClass="nav-item"
                      spacing="12" alignment="CENTER_LEFT"
                      onMouseClicked="#onNavEstudiantes">
                    <SVGPath styleClass="nav-svg-icon"
                             content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                             scaleX="0.9" scaleY="0.9"/>
                    <Label text="Estudiantes" styleClass="nav-item__label"/>
                </HBox>

                <HBox fx:id="navHorario" styleClass="nav-item"
                      spacing="12" alignment="CENTER_LEFT"
                      onMouseClicked="#onNavHorario">
                    <SVGPath styleClass="nav-svg-icon"
                             content="M20 3h-1V1h-2v2H7V1H5v2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H4V8h16v13z"
                             scaleX="0.9" scaleY="0.9"/>
                    <Label text="Horario" styleClass="nav-item__label"/>
                </HBox>

                <HBox fx:id="navConfig" styleClass="nav-item"
                      spacing="12" alignment="CENTER_LEFT"
                      onMouseClicked="#onNavConfig">
                    <SVGPath styleClass="nav-svg-icon"
                             content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                             scaleX="0.9" scaleY="0.9"/>
                    <Label text="Configuración" styleClass="nav-item__label"/>
                </HBox>
            </VBox>


            <!-- Perfil + Logout -->
            <HBox styleClass="side-navbar__profile" spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="avatar avatar--md avatar--blue">
                    <Label text="AU" styleClass="avatar__initials"/>
                </StackPane>
                <VBox VBox.vgrow="ALWAYS" spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Admin User"       styleClass="profile-name"/>
                    <Label text="admin@lumina.edu" styleClass="profile-email"/>
                </VBox>
                <!--
                    Icono logout: logout
                    content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58
                    2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0
                    1.1.9 2 2 2h8v-2H4V5z"
                -->
                <Button fx:id="btnLogout" styleClass="btn-icon-ghost"
                        mnemonicParsing="false" onAction="#onLogout">
                    <graphic>
                        <SVGPath styleClass="nav-svg-icon"
                                 content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"
                                 scaleX="0.85" scaleY="0.85"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" VBox.vgrow="ALWAYS">

            <!-- TopBar -->
            <HBox fx:id="topAppBar" styleClass="top-app-bar"
                  alignment="CENTER_LEFT" spacing="16">

                <HBox styleClass="search-bar" alignment="CENTER_LEFT" spacing="8">
                    <!--
                        Icono search en la barra:
                        content="M15.5 14h-.79l-.28-.27C15.41 12.59 16
                        11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3
                        9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57
                        l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01
                        14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5
                        11.99 14 9.5 14z"
                    -->
                    <SVGPath styleClass="search-svg-icon"
                             content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                             scaleX="0.75" scaleY="0.75"/>
                    <TextField fx:id="searchField"
                               promptText="Buscar expedientes, cursos o reportes..."
                               styleClass="search-bar__input"
                               prefWidth="320"
                               onKeyReleased="#onSearch"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Notificaciones -->
                <StackPane>
                    <Button fx:id="btnNotifications" styleClass="btn-icon-ghost"
                            mnemonicParsing="false">
                        <graphic>
                            <!--
                                Icono notifications:
                                content="M12 22c1.1 0 2-.9 2-2h-4c0
                                1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64
                                -4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5
                                .67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5
                                l-2 2v1h16v-1l-2-2z"
                            -->
                            <SVGPath styleClass="nav-svg-icon"
                                     content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                                     scaleX="0.85" scaleY="0.85"/>
                        </graphic>
                    </Button>
                    <Circle fx:id="notifBadge" radius="4" styleClass="notif-badge"
                            StackPane.alignment="TOP_RIGHT"
                            translateX="4" translateY="-4"/>
                </StackPane>

                <!-- Ayuda -->
                <Button styleClass="btn-icon-ghost" mnemonicParsing="false">
                    <graphic>
                        <!--
                            Icono help_outline:
                            content="M11 18h2v-2h-2v2zm1-16C6.48 2 2
                            6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52
                            2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8
                            8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79
                            -4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3
                            5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"
                        -->
                        <SVGPath styleClass="nav-svg-icon"
                                 content="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"
                                 scaleX="0.85" scaleY="0.85"/>
                    </graphic>
                </Button>

                <!-- Mini-perfil -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <VBox alignment="CENTER_RIGHT" spacing="1">
                        <Label text="Admin"           styleClass="topbar-user-name"/>
                        <Label text="admin@lumina.edu" styleClass="topbar-user-email"/>
                    </VBox>
                    <StackPane styleClass="avatar avatar--md avatar--primary">
                        <Label text="A" styleClass="avatar__initials"/>
                    </StackPane>
                </HBox>

            </HBox>


            <!--Vista 1-->
            <StackPane fx:id="contentStack" VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="vistaListaCursos"
                            styleClass="main-scroll-pane"
                            fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED">
                    <VBox styleClass="content-area" spacing="24">

                        <VBox spacing="6">
                            <Label text="Listado Completo de Cursos" styleClass="page-title-lg"/>
                            <Label text="Bienvenido de nuevo.Aquí tienes un resumen del estado institucional hoy."
                                   styleClass="page-subtitle"/>
                        </VBox>

                        <VBox styleClass="list-table-container" spacing="0">

                            <!-- Header filtros-->
                            <VBox styleClass="list-table__header" spacing="12">
                                <Label fx:id="lblTotalCursos"
                                       text="Todos los Cursos(0)"
                                       styleClass="list-table__title"/>
                                <HBox spacing="8">
                                    <Button fx:id="FilterTodos" text="Todos"
                                            styleClass="filter-pill filter-pill--active"
                                            mnemonicParsing="false" onAction="#onFilterTodos"/>
                                    <Button fx:id="filterActivos" text="Activos"
                                            styleClass="filter-pill"
                                            mnemonicParsing="false" onAction="#onFilterActivos"/>

                                </HBox>
                            </VBox>

                            <!--TableView Cursos-->
                            <TableView fx:id="cursosTable"
                                       styleClass="courses-table"
                                       columnResizePolicy="CONSTRAINED_RESIZE_POLICY">
                                <columns>
                                    <TableColumn fx:id="colGrado" text="Grado" prefWidth="80" minWidth="70"/>
                                    <TableColumn fx:id="colEncargado" text="Encargado" prefWidth="220" minWidth="160"/>
                                    <TableColumn fx:id="colSeccion" text="Sección" prefWidth="90" minWidth="70"/>
                                    <TableColumn fx:id="colAlumnos" text="Alumnos" prefWidth="110" minWidth="80"/>
                                    <TableColumn fx:id="colRendimiento" text="Rendimiento Promedio" prefWidth="190" minWidth="140"/>
                                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="120" minWidth="100"/>

                                </columns>
                                <placeholder>
                                    <Label text="No hay cursos que mostrar." styleClass="table-placeholder-label"/>
                                </placeholder>
                            </TableView>

                            <!-- Paginación -->
                            <HBox styleClass="pagination-bar" alignment="CENTER_LEFT">
                                <Label fx:id="lblPaginacion"
                                       text="Mostrando 7 de 36 cursos"
                                       styleClass="pagination-info"
                                       HBox.hgrow="ALWAYS"/>
                                <HBox spacing="4">
                                    <Button fx:id="btnPage1"    text="1" styleClass="page-btn page-btn--active"
                                            mnemonicParsing="false" onAction="#onPage1"/>
                                    <Button fx:id="btnPage2"    text="2" styleClass="page-btn"
                                            mnemonicParsing="false" onAction="#onPage2"/>
                                    <Button fx:id="btnPage3"    text="3" styleClass="page-btn"
                                            mnemonicParsing="false" onAction="#onPage3"/>
                                    <Button fx:id="btnPageNext" text="›" styleClass="page-btn"
                                            mnemonicParsing="false" onAction="#onPageNext"/>
                                </HBox>
                            </HBox>

                        </VBox>
                    </VBox>
                </ScrollPane>
                <!-- ──────────── FIN VISTA 1 ──────────── -->


                <!-- ████████████████████████████████████████████████████████
                     VISTA 2 — DETALLE DEL CURSO  (oculta al inicio)
                ████████████████████████████████████████████████████████ -->
                <ScrollPane fx:id="vistaDetalleCurso"
                            styleClass="main-scroll-pane"
                            fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            visible="false"
                            managed="false">

                    <VBox styleClass="content-area" spacing="32">

                        <!-- Page Header -->
                        <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label fx:id="breadcrumbCursos"
                                           text="Cursos"
                                           styleClass="breadcrumb__parent breadcrumb__link"
                                           onMouseClicked="#onBreadcrumbCursos"/>
                                    <Label text="›" styleClass="breadcrumb__separator"/>
                                    <Label fx:id="breadcrumbCursoActual"
                                           text="5to E"
                                           styleClass="breadcrumb__current"/>
                                </HBox>
                                <Label fx:id="pageTitle"
                                       text="Detalles del Curso: 5to E"
                                       styleClass="page-title"/>
                            </VBox>

                            <!-- Botón Imprimir -->
                            <Button fx:id="btnPrint" styleClass="btn-outlined"
                                    mnemonicParsing="false" onAction="#onImprimirReporte">
                                <graphic>
                                    <HBox spacing="8" alignment="CENTER">
                                        <!--
                                            Icono print:
                                            content="M19 8H5c-1.66 0-3
                                            1.34-3 3v6h4v4h12v-4h4v-6c0
                                            -1.66-1.34-3-3-3zm-3 11H8v-5
                                            h8v5zm3-7c-.55 0-1-.45-1-1s
                                            .45-1 1-1 1 .45 1 1-.45 1-1
                                            1zm-1-9H6v4h12V3z"
                                        -->
                                        <SVGPath styleClass="btn-svg-icon"
                                                 content="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"
                                                 scaleX="0.8" scaleY="0.8"/>
                                        <Label text="Imprimir Reporte"/>
                                    </HBox>
                                </graphic>
                            </Button>

                            <!-- Botón Editar -->
                            <Button fx:id="btnEditCourse" styleClass="btn-primary"
                                    mnemonicParsing="false" onAction="#onEditarCurso">
                                <graphic>
                                    <HBox spacing="8" alignment="CENTER">
                                        <!--
                                            Icono edit:
                                            content="M3 17.25V21h3.75L17.81
                                            9.94l-3.75-3.75L3 17.25zM20.71
                                            7.04c.39-.39.39-1.02 0-1.41l
                                            -2.34-2.34c-.39-.39-1.02-.39
                                            -1.41 0l-1.83 1.83 3.75 3.75
                                            1.83-1.83z"
                                        -->
                                        <SVGPath styleClass="btn-svg-icon btn-svg-icon--white"
                                                 content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                                 scaleX="0.8" scaleY="0.8"/>
                                        <Label text="Editar Curso" styleClass="btn-primary__label"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <!-- Bento Grid 4/8 -->
                        <GridPane fx:id="bentoGrid" styleClass="bento-grid" hgap="24" vgap="24">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.33"/>
                                <ColumnConstraints percentWidth="66.67"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints vgrow="ALWAYS"/>
                            </rowConstraints>

                            <!-- ─── Overview Card (col 0) ─────────────── -->
                            <VBox fx:id="courseOverviewCard" styleClass="card" spacing="16"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0">

                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Resumen" styleClass="card__title" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="badgeNivel" text="SECUNDARIA"
                                           styleClass="badge badge--surface"/>
                                </HBox>

                                <StackPane styleClass="course-image-container" prefHeight="192">
                                    <Pane styleClass="course-image-placeholder"/>
                                    <Pane styleClass="course-image-overlay"/>
                                    <VBox styleClass="course-image-caption"
                                          StackPane.alignment="BOTTOM_LEFT">
                                        <Label text="Tutor Principal" styleClass="caption-subtitle"/>
                                        <Label fx:id="lblTutorPrincipal"
                                               text="Prof. Laura Méndez" styleClass="caption-title"/>
                                    </VBox>
                                </StackPane>

                                <VBox spacing="8">

                                    <!-- Stat: Total Estudiantes -->
                                    <HBox styleClass="stat-row" spacing="12" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon stat-icon--primary">
                                            <!--
                                                Icono group (estudiantes):
                                                content="M16 11c1.66 0 2.99-1.34
                                                2.99-3S17.66 5 16 5c-1.66 0-3
                                                1.34-3 3s1.34 3 3 3zm-8 0c1.66
                                                0 2.99-1.34 2.99-3S9.66 5 8
                                                5C6.34 5 5 6.34 5 8s1.34 3 3
                                                3zm0 2c-2.33 0-7 1.17-7 3.5V19
                                                h14v-2.5c0-2.33-4.67-3.5-7-3.5z
                                                m8 0c-.29 0-.62.02-.97.05 1.16
                                                .84 1.97 1.97 1.97 3.45V19h6v
                                                -2.5c0-2.33-4.67-3.5-7-3.5z"
                                            -->
                                            <SVGPath styleClass="stat-svg-icon"
                                                     content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                                     scaleX="0.7" scaleY="0.7"/>
                                        </StackPane>
                                        <VBox>
                                            <Label text="Total Estudiantes" styleClass="stat-label"/>
                                            <Label fx:id="totalStudents" text="32" styleClass="stat-value"/>
                                        </VBox>
                                    </HBox>

                                    <!-- Stat: Total Profesores -->
                                    <HBox styleClass="stat-row" spacing="12" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon stat-icon--secondary">
                                            <!--
                                                Icono school (profesores):
                                                content="M5 13.18v4L12 21l7-3.82
                                                v-4L12 17l-7-3.82zM12 3L1 9l11
                                                6 9-4.91V17h2V9L12 3z"
                                            -->
                                            <SVGPath styleClass="stat-svg-icon"
                                                     content="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"
                                                     scaleX="0.7" scaleY="0.7"/>
                                        </StackPane>
                                        <VBox>
                                            <Label text="Total Profesores" styleClass="stat-label"/>
                                            <Label fx:id="totalTeachers" text="8" styleClass="stat-value"/>
                                        </VBox>
                                    </HBox>

                                    <!-- Stat: Aula Asignada -->
                                    <HBox styleClass="stat-row" spacing="12" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon stat-icon--neutral">
                                            <!--
                                                Icono door_front / room:
                                                content="M12 3L4 9v12h16V9l-8
                                                -6zm0 2.35L18 9.86V19h-3v-4H9v4
                                                H6V9.86L12 5.35z"
                                            -->
                                            <SVGPath styleClass="stat-svg-icon stat-svg-icon--dark"
                                                     content="M12 3L4 9v12h16V9l-8-6zm0 2.35L18 9.86V19h-3v-4H9v4H6V9.86L12 5.35z"
                                                     scaleX="0.7" scaleY="0.7"/>
                                        </StackPane>
                                        <VBox>
                                            <Label text="Aula Asignada" styleClass="stat-label"/>
                                            <Label fx:id="assignedRoom"
                                                   text="Pabellón B - Aula 204"
                                                   styleClass="stat-value"/>
                                        </VBox>
                                    </HBox>

                                </VBox>
                            </VBox>

                            <!-- ─── Columna derecha (col 1) ──────────── -->
                            <VBox spacing="24"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0"
                                  VBox.vgrow="ALWAYS">

                                <!-- Equipo Docente -->
                                <VBox styleClass="card" spacing="16">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Equipo Docente" styleClass="card__title"
                                               HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="btnVerTodosDocentes" text="Ver Todos"
                                                styleClass="btn-link" mnemonicParsing="false"
                                                onAction="#onVerTodosDocentes"/>
                                    </HBox>
                                    <GridPane hgap="16" vgap="12">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>
                                        <HBox styleClass="teacher-card" spacing="12" alignment="CENTER_LEFT"
                                              GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <StackPane styleClass="avatar avatar--md avatar--blue">
                                                <Label text="CR" styleClass="avatar__initials"/>
                                            </StackPane>
                                            <VBox spacing="2">
                                                <Label text="Carlos Ruiz" styleClass="teacher-name"/>
                                                <Label text="Matemáticas Avanzadas" styleClass="teacher-subject"/>
                                            </VBox>
                                        </HBox>
                                        <HBox styleClass="teacher-card" spacing="12" alignment="CENTER_LEFT"
                                              GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <StackPane styleClass="avatar avatar--md avatar--green">
                                                <Label text="ET" styleClass="avatar__initials"/>
                                            </StackPane>
                                            <VBox spacing="2">
                                                <Label text="Elena Torres" styleClass="teacher-name"/>
                                                <Label text="Física y Química" styleClass="teacher-subject"/>
                                            </VBox>
                                        </HBox>
                                        <HBox styleClass="teacher-card" spacing="12" alignment="CENTER_LEFT"
                                              GridPane.columnIndex="0" GridPane.rowIndex="1">
                                            <StackPane styleClass="avatar avatar--md avatar--amber">
                                                <Label text="MS" styleClass="avatar__initials"/>
                                            </StackPane>
                                            <VBox spacing="2">
                                                <Label text="Miguel Ángel Soto" styleClass="teacher-name"/>
                                                <Label text="Literatura Hispanoam." styleClass="teacher-subject"/>
                                            </VBox>
                                        </HBox>
                                        <HBox styleClass="teacher-card" spacing="12" alignment="CENTER_LEFT"
                                              GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <StackPane styleClass="avatar avatar--md avatar--teal">
                                                <Label text="AS" styleClass="avatar__initials"/>
                                            </StackPane>
                                            <VBox spacing="2">
                                                <Label text="Ana Silva" styleClass="teacher-name"/>
                                                <Label text="Historia Universal" styleClass="teacher-subject"/>
                                            </VBox>
                                        </HBox>
                                    </GridPane>
                                </VBox>

                                <!-- Lista de Estudiantes -->
                                <VBox styleClass="card students-card" spacing="0" VBox.vgrow="ALWAYS">
                                    <HBox styleClass="students-card__header"
                                          alignment="CENTER_LEFT" spacing="16">
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label text="Lista de Estudiantes" styleClass="card__title"/>
                                            <Label fx:id="studentsSubtitle"
                                                   text="32 alumnos inscritos en el ciclo actual"
                                                   styleClass="card__subtitle"/>
                                        </VBox>
                                        <HBox styleClass="view-toggle" spacing="0">
                                            <ToggleButton fx:id="btnViewTable" text="Tabla"
                                                          styleClass="view-toggle__btn view-toggle__btn--active"
                                                          selected="true" mnemonicParsing="false"/>
                                            <ToggleButton fx:id="btnViewGrid" text="Cuadrícula"
                                                          styleClass="view-toggle__btn"
                                                          mnemonicParsing="false"/>
                                        </HBox>
                                    </HBox>

                                    <TableView fx:id="studentsTable"
                                               styleClass="students-table"
                                               VBox.vgrow="ALWAYS"
                                               columnResizePolicy="CONSTRAINED_RESIZE_POLICY">
                                        <columns>
                                            <TableColumn fx:id="colStudent"    text="ESTUDIANTE"   prefWidth="240"/>
                                            <TableColumn fx:id="colMatricula"  text="ID MATRÍCULA" prefWidth="140"/>
                                            <TableColumn fx:id="colAsistencia" text="ASISTENCIA"   prefWidth="160"/>
                                            <TableColumn fx:id="colAcciones"   text="ACCIONES"     prefWidth="80"/>
                                        </columns>
                                        <placeholder>
                                            <Label text="No hay estudiantes registrados."
                                                   styleClass="table-placeholder-label"/>
                                        </placeholder>
                                    </TableView>

                                    <HBox styleClass="students-card__footer" alignment="CENTER">
                                        <Button fx:id="btnLoadMore"
                                                text="Cargar más estudiantes"
                                                styleClass="btn-link-primary"
                                                mnemonicParsing="false"
                                                onAction="#onCargarMas"/>
                                    </HBox>
                                </VBox>

                            </VBox>
                        </GridPane>
                    </VBox>
                </ScrollPane>
                <!-- ──────────── FIN VISTA 2 ──────────── -->

            </StackPane>
        </VBox>
    </center>

</BorderPane>
