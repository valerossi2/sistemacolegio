<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<VBox fx:id="cursosRoot"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.edugrade.controllers.CursoController"
      styleClass="cursos-root"
      spacing="0"
      maxWidth="Infinity"
      stylesheets="@../../css/Cursos.css">
      <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <VBox spacing="8" styleClass="cursos-page-header">
        <padding>
            <Insets bottom="32"/>
        </padding>
        <Text fx:id="pageTitle" text="Listado Completo de Cursos" styleClass="cursos-page-title" />
        <Text fx:id="pageSubtitle" text="Bienvenido de nuevo. Aquí tienes un resumen del estado institucional hoy." styleClass="cursos-page-subtitle" />
    </VBox>

    <VBox styleClass="cursos-card" VBox.vgrow="ALWAYS" spacing="0">
        <HBox styleClass="cursos-card__header" alignment="CENTER_LEFT">
            <Label fx:id="lblTotalCursos" text="Todos los Cursos (35)" styleClass="cursos-card__title" />
        </HBox>

        <TableView fx:id="cursosTable"
                   styleClass="cursos-table"
                   VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colGrado"       text="GRADO"     styleClass="col-grado" />
                <TableColumn fx:id="colEncargado"   text="ENCARGADO" styleClass="col-encargado" />
                <TableColumn fx:id="colSeccion"     text="SECCIÓN"   styleClass="col-seccion" />
                <TableColumn fx:id="colAlumnos"     text="ALUMNOS"   styleClass="col-alumnos" />
                <TableColumn fx:id="colRendimiento" text="RENDIMIENTO PROMEDIO" styleClass="col-rendimiento" />
                <TableColumn fx:id="colEstado"      text="ESTADO"    styleClass="col-estado" />
                <TableColumn fx:id="colAcciones"    text="ACCIONES"  styleClass="col-acciones" />
            </columns>
            <placeholder>
                <Label text="No hay cursos que mostrar." styleClass="cursos-placeholder" />
            </placeholder>
        </TableView>
    </VBox>
</VBox>
