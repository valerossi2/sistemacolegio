<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.edugrade.controllers.CursoController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="main-scroll-pane"
            stylesheets="@../../css/Cursos.css">

    <VBox spacing="24" styleClass="content-area">
        <padding>
            <Insets top="32" right="40" bottom="40" left="40"/>
        </padding>

        <VBox spacing="6">
            <Text fx:id="pageTitle" text="Listado Completo de Cursos" styleClass="page-title-lg" />
            <Text fx:id="pageSubtitle" text="Gestiona los cursos activos del instituto." styleClass="page-subtitle" />
        </VBox>

        <VBox styleClass="list-table-container" VBox.vgrow="ALWAYS" spacing="0">
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="list-table__header">
                <Label fx:id="lblTotalCursos" text="Todos los Cursos (0)" styleClass="list-table__title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="filterTodos" text="Todos" styleClass="filter-pill, filter-pill--active" onAction="#onFilterTodos" />
                <Button fx:id="filterActivos" text="Activos" styleClass="filter-pill" onAction="#onFilterActivos" />
            </HBox>

            <TableView fx:id="cursosTable"
                       styleClass="courses-table"
                       VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colGrado"       text="Grado"               prefWidth="80"  minWidth="70"/>
                    <TableColumn fx:id="colEncargado"   text="Encargado"            prefWidth="220" minWidth="160"/>
                    <TableColumn fx:id="colSeccion"     text="Sección"              prefWidth="90"  minWidth="70"/>
                    <TableColumn fx:id="colAlumnos"     text="Alumnos"              prefWidth="110" minWidth="80"/>
                    <TableColumn fx:id="colRendimiento" text="Rendimiento Promedio" prefWidth="190" minWidth="140"/>
                    <TableColumn fx:id="colEstado"      text="Estado"               prefWidth="120" minWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No hay cursos que mostrar." styleClass="table-placeholder-label" />
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" styleClass="pagination-bar">
                <Label fx:id="lblPaginacion" text="Mostrando 5 de 5 cursos" styleClass="pagination-info" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="4" alignment="CENTER_RIGHT">
                    <Button fx:id="btnPage1" text="1" styleClass="page-btn, page-btn--active" onAction="#onPage1" />
                    <Button fx:id="btnPage2" text="2" styleClass="page-btn" onAction="#onPage2" />
                    <Button fx:id="btnPage3" text="3" styleClass="page-btn" onAction="#onPage3" />
                    <Button fx:id="btnPageNext" text="›" styleClass="page-btn" onAction="#onPageNext" />
                </HBox>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
