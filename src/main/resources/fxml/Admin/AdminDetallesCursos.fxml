<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>


<!--
    VISTA 2 — DETALLE DEL CURSO
    Se carga dinámicamente desde CursoController y se inyecta
    en el contentStack del padre (Cursos.fxml).
    Controller propio: com.edugrade.controllers.DetalleCursoController
-->
<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.edugrade.controllers.DetalleCursoController"
            fx:id="vistaDetalleCurso"
            styleClass="main-scroll-pane"
            stylesheets="@../../css/base.css,@../../css/DetallesCurso.css"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

    <VBox fx:id="root" styleClass="content-area" spacing="32">

        <!-- ════════════════════════════════════════
             Page Header — Breadcrumb + Acciones
        ════════════════════════════════════════ -->
        <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label fx:id="breadcrumbCursos"
                           text="Cursos"
                           styleClass="breadcrumb__parent btn-link"
                           onMouseClicked="#onBreadcrumbCursos"/>
                    <Label text="›" styleClass="breadcrumb__separator"/>
                    <Label fx:id="breadcrumbCursoActual"
                           text="5to E"
                           styleClass="breadcrumb__current breadcrumb__link"
                           onMouseClicked="#onBreadcrumbCursoActual"/>
                </HBox>
                <Label fx:id="pageTitle"
                       text="Detalles del Curso: 5to E"
                       styleClass="page-title"/>
            </VBox>

            <!-- Botón Imprimir -->
            <Button fx:id="btnPrint" styleClass="btn-outlined"
                    mnemonicParsing="false" onAction="#onImprimirReporte">
                <graphic>
                    <SVGPath styleClass="btn-svg-icon"
                             content="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"
                             scaleX="0.8" scaleY="0.8"/>
                </graphic>
            </Button>

            <!-- Botón Editar / Guardar -->
            <Button fx:id="btnEditCourse" styleClass="btn-primary"
                    mnemonicParsing="false" onAction="#onEditarCurso">
                <graphic>
                    <SVGPath styleClass="btn-svg-icon btn-svg-icon--white"
                             content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                             scaleX="0.8" scaleY="0.8"/>
                </graphic>
            </Button>
            <!-- Botón Cancelar (visible solo en modo edición) -->
            <Button fx:id="btnCancelEdit" styleClass="btn-outlined"
                    mnemonicParsing="false" onAction="#onCancelarEdicion"
                    visible="false" managed="false">
                <graphic>
                    <SVGPath styleClass="btn-svg-icon"
                             content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                             scaleX="0.8" scaleY="0.8"/>
                </graphic>
            </Button>
            <!-- Botón Calificaciones -->
            <Button fx:id="btnCalificaciones" styleClass="btn-outlined"
                    mnemonicParsing="false" onAction="#onCalificaciones">
                <graphic>
                    <SVGPath styleClass="btn-svg-icon"
                             content="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h10v2H4v-2z"
                             scaleX="0.8" scaleY="0.8"/>
                </graphic>
            </Button>
        </HBox>

        <!-- ════════════════════════════════════════
             Edit Forms Panel (hidden, shown in edit mode)
        ════════════════════════════════════════ -->
        <VBox fx:id="editFormsPanel" spacing="16" visible="false" managed="false">
            <padding><Insets left="40" right="40"/></padding>
            <VBox styleClass="card" spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label fx:id="lblAddStudentTitle" text="Agregar Estudiante" styleClass="card__title"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="studentNameField"
                               promptText="Nombre del estudiante"
                               HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="studentIdField"
                               promptText="ID Matr\u00edcula"
                               prefWidth="140"/>
                    <Button fx:id="addStudentBtn" styleClass="btn-primary"
                            mnemonicParsing="false" onAction="#onAddStudent">
                        <graphic>
                            <SVGPath styleClass="btn-svg-icon btn-svg-icon--white"
                                     content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                     scaleX="0.8" scaleY="0.8"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
            <VBox styleClass="card" spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label fx:id="lblAddTeacherTitle" text="Agregar Profesor" styleClass="card__title"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane HBox.hgrow="ALWAYS">
                        <TextField fx:id="teacherSearchField"
                                   promptText="Buscar profesor..."
                                   HBox.hgrow="ALWAYS"/>
                    </StackPane>
                    <Button fx:id="addTeacherBtn" styleClass="btn-primary"
                            mnemonicParsing="false" onAction="#onAddTeacher">
                        <graphic>
                            <SVGPath styleClass="btn-svg-icon btn-svg-icon--white"
                                     content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                     scaleX="0.8" scaleY="0.8"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>

        <!-- ════════════════════════════════════════
             Bento Grid 33 / 67
        ════════════════════════════════════════ -->
        <GridPane fx:id="bentoGrid" styleClass="bento-grid" hgap="24" vgap="24">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="66.67"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>

            <!-- ─── Columna izquierda: Estadísticas y Rendimiento ─── -->
            <VBox fx:id="courseOverviewCard" styleClass="card" spacing="16"
                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label fx:id="lblStatsTitle" text="Estadísticas y Rendimiento"
                       styleClass="card__title"/>

                <VBox spacing="8">
                    <HBox styleClass="stat-row" spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon stat-icon--primary">
                            <SVGPath styleClass="stat-svg-icon"
                                     content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                     scaleX="0.7" scaleY="0.7"/>
                        </StackPane>
                        <VBox>
                            <Label fx:id="lblTotalStudentsLabel" text="Total Estudiantes" styleClass="stat-label"/>
                            <Label fx:id="totalStudents" text="32" styleClass="stat-value"/>
                        </VBox>
                    </HBox>

                    <HBox styleClass="stat-row" spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon stat-icon--secondary">
                            <SVGPath styleClass="stat-svg-icon"
                                     content="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"
                                     scaleX="0.7" scaleY="0.7"/>
                        </StackPane>
                        <VBox>
                            <Label fx:id="lblTotalTeachersLabel" text="Total Profesores" styleClass="stat-label"/>
                            <Label fx:id="totalTeachers" text="8" styleClass="stat-value"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Region styleClass="card-divider"/>

                <VBox spacing="10">
                    <HBox spacing="8">
                        <VBox styleClass="stat-mini-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblPromedioGeneralLabel" text="Promedio General" styleClass="stat-mini-card__label"/>
                            <Label fx:id="lblPromedioGeneral" text="0.0" styleClass="stat-mini-card__value"/>
                        </VBox>
                        <VBox styleClass="stat-mini-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblAprobadosReprobadosLabel" text="Aprobados / Reprobados" styleClass="stat-mini-card__label"/>
                            <Label fx:id="lblAprobadosReprobados" text="0 / 0" styleClass="stat-mini-card__value"/>
                        </VBox>
                    </HBox>
                    <VBox styleClass="stat-mini-card">
                        <Label fx:id="lblPromedioMateriaLabel" text="Promedio por Materia" styleClass="stat-mini-card__label"/>
                        <Label fx:id="lblPromedioMateria" text="-" styleClass="stat-mini-card__value" wrapText="true"/>
                    </VBox>
                </VBox>

                <Region styleClass="card-divider"/>

                <VBox spacing="8">
                    <Label fx:id="lblDistribucionGeneroLabel" text="Distribución por Género" styleClass="card__subtitle"/>
                    <PieChart fx:id="genderChart"
                              styleClass="gender-chart"
                              legendVisible="true"
                              labelsVisible="true"
                              prefHeight="200"
                              animated="false"/>
                </VBox>

            </VBox>

            <!-- ─── Columna derecha ──────────── -->
            <VBox spacing="24"
                  GridPane.columnIndex="1" GridPane.rowIndex="0"
                  VBox.vgrow="ALWAYS">

                <!-- Equipo Docente -->
                <VBox styleClass="card" spacing="0">
                    <HBox styleClass="teacher-card__header" alignment="CENTER_LEFT">
                        <Label fx:id="lblEquipoDocenteCard" text="Equipo Docente" styleClass="card__title"
                               HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnVerTodosDocentes" text="Ver Todos"
                                styleClass="btn-link" mnemonicParsing="false"
                                onAction="#onVerTodosDocentes"/>
                    </HBox>
                    <TableView fx:id="teacherTable"
                               styleClass="teacher-table"
                               VBox.vgrow="NEVER">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colTeacherName" text="DOCENTE" prefWidth="200"/>
                            <TableColumn fx:id="colTeacherSubject" text="MATERIA" prefWidth="200"/>
                            <TableColumn fx:id="colTeacherHorario" text="HORARIO" prefWidth="180"/>
                        </columns>
                        <placeholder>
                            <Label text="No hay docentes asignados." styleClass="table-placeholder-label"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- Lista de Estudiantes -->
                <VBox styleClass="card" spacing="0">
                    <HBox styleClass="teacher-card__header" alignment="CENTER_LEFT">
                        <Label fx:id="lblListaEstudiantesCard" text="Lista de Estudiantes" styleClass="card__title"
                               HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnLoadMore" text="Cargar más estudiantes"
                                styleClass="btn-link" mnemonicParsing="false"
                                onAction="#onCargarMas"/>
                    </HBox>
                    <TableView fx:id="studentsTable"
                               styleClass="teacher-table"
                               VBox.vgrow="NEVER">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colStudent"    text="ESTUDIANTE"   prefWidth="200"/>
                            <TableColumn fx:id="colGenero"    text="GENERO"       prefWidth="60"/>
                            <TableColumn fx:id="colMatricula"  text="ID MATRÍCULA" prefWidth="120"/>
                            <TableColumn fx:id="colAsistencia" text="ASISTENCIA"   prefWidth="160"/>
                        </columns>
                        <placeholder>
                            <Label text="No hay estudiantes registrados."
                                   styleClass="table-placeholder-label"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </GridPane>

    </VBox>
</ScrollPane>
