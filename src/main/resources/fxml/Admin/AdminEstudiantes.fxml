<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<VBox fx:id="root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.EstudiantesController"
      styleClass="content-area"
      spacing="0"
      maxWidth="Infinity"
      stylesheets="@../../css/base.css,@../../css/DetallesCurso.css">

    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
        <padding><Insets top="40" right="40" bottom="0" left="40"/></padding>
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Text text="Gestión de Estudiantes" styleClass="cursos-page-title" />
            <Text text="Administra los estudiantes del instituto." styleClass="cursos-page-subtitle" />
        </VBox>
        <Button fx:id="btnPrint" styleClass="btn-outlined"
                mnemonicParsing="false" onAction="#onImprimirReporte">
            <graphic>
                <SVGPath styleClass="btn-svg-icon"
                         content="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"
                         scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>
    </HBox>

    <VBox styleClass="cursos-card" VBox.vgrow="ALWAYS" alignment="CENTER">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
        <Label text="Módulo de Estudiantes - Próximamente" style="-fx-font-size: 18px; -fx-text-fill: #9CA3AF;" />
    </VBox>
</VBox>
