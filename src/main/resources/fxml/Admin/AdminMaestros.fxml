<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<VBox fx:id="root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.edugrade.controllers.MaestrosController"
      styleClass="cursos-root"
      spacing="0"
      maxWidth="Infinity"
      maxHeight="Infinity"
      stylesheets="@../../css/base.css,@../../css/Cursos.css,@../../css/DetallesCurso.css">

    <VBox fx:id="maestrosCard" styleClass="cursos-card" VBox.vgrow="ALWAYS" spacing="0">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox fx:id="headerBox" spacing="6" HBox.hgrow="ALWAYS">
                <padding><Insets top="32" right="40" bottom="0" left="40"/></padding>
                <Text fx:id="pageTitle" text="Listado de Profesores" styleClass="cursos-page-title" />
                <Text fx:id="pageSubtitle" text="Gestiona los profesores activos del instituto." styleClass="cursos-page-subtitle" />
            </VBox>
            <Button fx:id="btnPrint" styleClass="btn-outlined"
                    mnemonicParsing="false" onAction="#onImprimirReporte">
                <graphic>
                    <SVGPath styleClass="btn-svg-icon"
                             content="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"
                             scaleX="0.8" scaleY="0.8"/>
                </graphic>
            </Button>
        </HBox>

        <HBox fx:id="countBox" alignment="CENTER_LEFT">
            <padding><Insets top="24" right="40" bottom="16" left="40"/></padding>
            <Label fx:id="lblTotalMaestros" text="Todos los Profesores (5)" styleClass="cursos-card__title" />
        </HBox>

        <TableView fx:id="maestrosTable"
                   styleClass="cursos-table"
                   VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNombre"   text="NOMBRE"   />
                <TableColumn fx:id="colEmail"    text="EMAIL"    />
                <TableColumn fx:id="colMateria"  text="MATERIA"  />
                <TableColumn fx:id="colSeccion"  text="SECCIÓN"  />
                <TableColumn fx:id="colEstado"   text="ESTADO"   />
                <TableColumn fx:id="colRol"      text="ROL"      />
                <TableColumn fx:id="colAcciones" text="ACCIONES" />
            </columns>
            <placeholder>
                <Label text="No hay profesores que mostrar." styleClass="cursos-placeholder" />
            </placeholder>
        </TableView>

    </VBox>
</VBox>
