<?xml version="1.0" encoding="UTF-8" ?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox fx:id="root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.edugrade.controllers.MaestrosController"
      styleClass="cursos-root"
      spacing="0"
      maxWidth="Infinity"
      maxHeight="Infinity"
      stylesheets="@../../css/base.css,@../../css/Cursos.css">

    <VBox fx:id="maestrosCard" styleClass="cursos-card" VBox.vgrow="ALWAYS" spacing="0">
        <VBox spacing="6">
            <padding><Insets top="32" right="40" bottom="0" left="40"/></padding>
            <Text fx:id="pageTitle" text="Listado de Profesores" styleClass="cursos-page-title" />
            <Text fx:id="pageSubtitle" text="Gestiona los profesores activos del instituto." styleClass="cursos-page-subtitle" />
        </VBox>

        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="24" right="40" bottom="16" left="40"/></padding>
            <Label fx:id="lblTotalMaestros" text="Todos los Profesores (5)" styleClass="cursos-card__title" />
        </HBox>

        <TableView fx:id="maestrosTable"
                   styleClass="cursos-table"
                   VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNombre"   text="NOMBRE"   />
                <TableColumn fx:id="colEmail"    text="EMAIL"    />
                <TableColumn fx:id="colMateria"  text="MATERIA"  />
                <TableColumn fx:id="colSeccion"  text="SECCIÓN"  />
                <TableColumn fx:id="colEstado"   text="ESTADO"   />
                <TableColumn fx:id="colAcciones" text="ACCIONES" />
            </columns>
            <placeholder>
                <Label text="No hay profesores que mostrar." styleClass="cursos-placeholder" />
            </placeholder>
        </TableView>

    </VBox>
</VBox>
