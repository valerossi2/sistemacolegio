<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="root-bg"
      fx:controller="controller.LoginController"
      styleClass=""

      minWidth="820"
      minHeight="560">

    <StackPane styleClass="left-panel" prefWidth="350" maxWidth="380">

        <SVGPath styleClass="wave-shape"
                 content="M 0 0 L 270 0 Q 320 160 270 310 Q 240 460 270 620 L 0 620 Z"
                 StackPane.alignment="CENTER_LEFT"/>

        <VBox styleClass="left-text-box" maxWidth="240" spacing="10"
              StackPane.alignment="CENTER_LEFT">
            <StackPane.margin><Insets left="32"/></StackPane.margin>
            <Label styleClass="left-title" wrapText="true"
                   text="Gestiona Calificaciones&#10;y Progreso Académico&#10;con Facilidad"/>
            <Label styleClass="left-subtitle" wrapText="true"
                   text="¡Bienvenido de nuevo! Por favor,&#10;inicia sesión en tu cuenta."/>
        </VBox>

        <ImageView fx:id="heroImage" fitWidth="220" fitHeight="180"
                   preserveRatio="true"
                   StackPane.alignment="BOTTOM_LEFT">
            <image>
                <Image url="@../../../../../img/logoCEPVAremove.png"/>
            </image>
            <StackPane.margin><Insets bottom="20" left="20"/></StackPane.margin>
        </ImageView>

    </StackPane>

    <StackPane styleClass="right-panel" HBox.hgrow="ALWAYS">
        <VBox styleClass="form-container" maxWidth="340" spacing="12"
              alignment="CENTER" StackPane.alignment="CENTER">

            <HBox styleClass="field-wrapper" alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="field-icon" text="✉"/>
                <TextField fx:id="emailField" styleClass="field-input"
                           promptText="Correo Electrónico" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox styleClass="field-wrapper" alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="field-icon" text="🔒"/>
                <PasswordField fx:id="passwordField" styleClass="field-input"
                               promptText="Contraseña" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="passwordVisible" styleClass="field-input"
                           promptText="Contraseña" visible="false" managed="false"
                           HBox.hgrow="ALWAYS"/>
                <Label styleClass="eye-button" text="👁" onMouseClicked="#togglePassword"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <CheckBox fx:id="rememberCheck" styleClass="remember-checkbox"
                          text="Recordarme"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink styleClass="forgot-link" text="¿Has olvidado tu contraseña?"
                           onAction="#onForgotPassword"/>
            </HBox>

            <Button text="Iniciar Sesión" styleClass="btn-primary"
                    maxWidth="Infinity" onAction="#onLogin">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <Button text="Registrarse" styleClass="btn-secondary"
                    maxWidth="Infinity" onAction="#goToRegister"/>

            <HBox alignment="CENTER" spacing="0">
                <VBox.margin><Insets top="4" bottom="4"/></VBox.margin>
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                <Label styleClass="divider-text" text="O inicia sesión con">
                    <HBox.margin><Insets left="10" right="10"/></HBox.margin>
                </Label>
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button styleClass="btn-google" maxWidth="Infinity" onAction="#onGoogle">
                <graphic>
                    <HBox alignment="CENTER" spacing="10">
                        <Label styleClass="google-logo" text="G"/>
                        <Label styleClass="google-text" text="Google"/>
                    </HBox>
                </graphic>
            </Button>

        </VBox>
    </StackPane>

</HBox>
