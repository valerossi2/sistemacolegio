<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.*?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.edugrade.controller.GradesController"
      styleClass="root-container"
      stylesheets="@../../css/Calificaciones.css"
      prefWidth="1280"
      prefHeight="800">

    <!-- ═══════════════════════════════════════════ -->
    <!--                   SIDEBAR                   -->
    <!-- ═══════════════════════════════════════════ -->
    <VBox fx:id="sidebar"
          styleClass="sidebar"
          prefWidth="256"
          minWidth="256">

        <!-- Logo / Brand -->
        <VBox styleClass="sidebar-logo-area">
            <HBox styleClass="sidebar-logo-inner" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="logo-icon-container">
                    <SVGPath styleClass="logo-icon"
                             content="M12 1L3 5v6c0 5.25 3.75 10.15 9 11.35C17.25 21.15 21 16.25 21 11V5L12 1zm0 4l6 2.67V11c0 3.78-2.58 7.3-6 8.47C8.58 18.3 6 14.78 6 11V7.67L12 5z"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="EduGrade Admin" styleClass="logo-title"/>
                    <Label text="Academic Management" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Navigation Menu -->
        <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS" spacing="2">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- Inicio -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M3 13h1v7c0 .55.45 1 1 1h4v-4h2v4h4c.55 0 1-.45 1-1v-7h1l-7-7-7 7z"/>
                <Label text="Inicio" styleClass="nav-label"/>
            </HBox>

            <!-- Estudiantes -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M12 3L1 9l4 2.18V17h2v-4.82L9 13.39V17c0 1.1 1.34 2 3 2s3-.9 3-2v-3.61l2-1.11V17h2v-5.82L23 9 12 3zm0 2.24L19.5 9 12 12.76 4.5 9 12 5.24z"/>
                <Label text="Estudiantes" styleClass="nav-label"/>
            </HBox>

            <!-- Cursos (ACTIVE) -->
            <HBox fx:id="navCursos" styleClass="nav-item, nav-item-active" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon-active"
                         content="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 14H7v-2h10v2zm0-4H7v-2h10v2zm0-4H7V6h10v2z"/>
                <Label text="Cursos" styleClass="nav-label-active"/>
            </HBox>

            <!-- Horario -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                <Label text="Horario" styleClass="nav-label"/>
            </HBox>

            <!-- Configuración -->
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12">
                <SVGPath styleClass="nav-icon"
                         content="M19.43 12.98c.04-.32.07-.65.07-.98 0-.33-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98 0 .33.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/>
                <Label text="Configuración" styleClass="nav-label"/>
            </HBox>
        </VBox>

        <!-- User Section -->
        <VBox styleClass="sidebar-user-area">
            <HBox styleClass="sidebar-user-card" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-avatar">
                    <Label text="A" styleClass="user-avatar-letter"/>
                </StackPane>
                <VBox HBox.hgrow="ALWAYS" spacing="1">
                    <Label text="Admin User" styleClass="user-name"/>
                    <Label text="admin@edugrade.edu" styleClass="user-email"/>
                </VBox>
                <SVGPath styleClass="user-logout-icon"
                         content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════════════ -->
    <!--                 MAIN AREA                   -->
    <!-- ═══════════════════════════════════════════ -->
    <VBox styleClass="main-area" HBox.hgrow="ALWAYS">

        <!-- TOP HEADER -->
        <HBox fx:id="topHeader" styleClass="top-header" alignment="CENTER_LEFT" spacing="0">

            <!-- Search Field -->
            <StackPane styleClass="search-wrapper" HBox.hgrow="ALWAYS">
                <SVGPath styleClass="search-icon"
                         content="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                <TextField fx:id="searchField"
                           promptText="Buscar..."
                           styleClass="search-field"
                           maxWidth="384"/>
            </StackPane>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Action Icons -->
            <HBox alignment="CENTER" spacing="20">
                <padding><Insets right="32"/></padding>
                <StackPane styleClass="header-icon-btn">
                    <SVGPath styleClass="header-icon"
                             content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
                    <Circle styleClass="notif-dot" radius="4" translateX="6" translateY="-6"/>
                </StackPane>
                <StackPane styleClass="header-icon-btn">
                    <SVGPath styleClass="header-icon"
                             content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                </StackPane>
            </HBox>
        </HBox>

        <!-- SCROLLABLE CONTENT -->
        <ScrollPane fx:id="contentScroll"
                    styleClass="content-scroll"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS">

            <VBox styleClass="content-area" spacing="0">
                <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                <!-- PAGE TITLE ROW -->
                <HBox alignment="BOTTOM_LEFT" spacing="0" styleClass="page-header-row">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="breadcrumb-row">
                            <SVGPath styleClass="back-icon"
                                     content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                            <Label text="Volver a Detalles del Curso: 5to E"
                                   styleClass="breadcrumb-label"/>
                        </HBox>
                        <Label text="Gestión de Calificaciones - 5to E"
                               styleClass="page-title"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="btnTipoEval"
                                text="Tipo de Evaluación"
                                styleClass="btn-secondary"/>
                        <Button fx:id="btnGuardarTop"
                                text="Guardar Cambios"
                                styleClass="btn-primary"/>
                    </HBox>
                </HBox>

                <!-- SPACER -->
                <Region prefHeight="28"/>

                <!-- FILTERS GRID -->
                <GridPane hgap="24" vgap="0" styleClass="filters-grid">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    </columnConstraints>

                    <!-- Periodo -->
                    <VBox GridPane.columnIndex="0" spacing="6">
                        <Label text="Periodo" styleClass="filter-label"/>
                        <ComboBox fx:id="comboPeriodo"
                                  styleClass="filter-combo"
                                  maxWidth="Infinity"
                                  prefHeight="42">
                            <items>
                                <javafx.collections.FXCollections fx:factory="observableArrayList">
                                    <String fx:value="P1 - Primer Periodo"/>
                                    <String fx:value="P2 - Segundo Periodo"/>
                                </javafx.collections.FXCollections>
                            </items>
                            <value><String fx:value="P1 - Primer Periodo"/></value>
                        </ComboBox>
                    </VBox>

                    <!-- Tipo de Evaluación -->
                    <VBox GridPane.columnIndex="1" spacing="6">
                        <Label text="Tipo de Evaluación" styleClass="filter-label"/>
                        <ComboBox fx:id="comboTipoEval"
                                  styleClass="filter-combo"
                                  maxWidth="Infinity"
                                  prefHeight="42">
                            <items>
                                <javafx.collections.FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Examen Parcial 1"/>
                                    <String fx:value="Trabajo Práctico"/>
                                </javafx.collections.FXCollections>
                            </items>
                            <value><String fx:value="Examen Parcial 1"/></value>
                        </ComboBox>
                    </VBox>
                </GridPane>

                <!-- SPACER -->
                <Region prefHeight="24"/>

                <!-- GRADES TABLE -->
                <VBox styleClass="table-card">
                    <TableView fx:id="gradesTable"
                               styleClass="grades-table"
                               prefHeight="320"
                               minHeight="220">
                        <columns>

                            <!-- Student column (custom cell) -->
                            <TableColumn fx:id="colEstudiante"
                                         text="ESTUDIANTE"
                                         styleClass="table-col-header"
                                         prefWidth="300"
                                         minWidth="240"/>

                            <!-- ID Matrícula -->
                            <TableColumn fx:id="colMatricula"
                                         text="ID MATRÍCULA"
                                         styleClass="table-col-header"
                                         prefWidth="180"
                                         minWidth="140"/>

                            <!-- Calificación Actual -->
                            <TableColumn fx:id="colCalifActual"
                                         text="CALIFICACIÓN ACTUAL"
                                         styleClass="table-col-header"
                                         prefWidth="200"
                                         minWidth="160"/>

                            <!-- Nueva Calificación (editable TextField) -->
                            <TableColumn fx:id="colNuevaCalif"
                                         text="NUEVA CALIFICACIÓN"
                                         styleClass="table-col-header"
                                         prefWidth="200"
                                         minWidth="160"/>

                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <placeholder>
                            <Label text="No hay estudiantes registrados." styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- SPACER -->
                <Region prefHeight="28"/>

                <!-- BOTTOM ACTION BUTTONS -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            styleClass="btn-secondary"/>
                    <Button fx:id="btnGuardarBottom"
                            text="Guardar Cambios"
                            styleClass="btn-primary"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>

</HBox>
