<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox fx:id="root"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.edugrade.controller.GradesController"
      styleClass="cursos-root"
      spacing="0"
      maxWidth="Infinity"
      maxHeight="Infinity"
      stylesheets="@../../css/base.css,@../../css/Cursos.css,@../../css/Calificaciones.css">

    <VBox fx:id="gradesCard" styleClass="cursos-card" VBox.vgrow="ALWAYS" spacing="0">
        <VBox spacing="6">
            <padding><Insets top="32" right="40" bottom="0" left="40"/></padding>
            <Text fx:id="pageTitle" text="Gestión de Calificaciones" styleClass="cursos-page-title" />
            <Text fx:id="pageSubtitle" text="Ingresa y gestiona las calificaciones de los estudiantes." styleClass="cursos-page-subtitle" />
        </VBox>

        <HBox spacing="16" alignment="CENTER_LEFT">
            <padding><Insets top="24" right="40" bottom="16" left="40"/></padding>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblPeriodo" text="Periodo" styleClass="input-label" />
                <ComboBox fx:id="comboPeriodo" maxWidth="Infinity" prefHeight="42" styleClass="input-field" />
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTipoEval" text="Tipo de Evaluación" styleClass="input-label" />
                <ComboBox fx:id="comboTipoEval" maxWidth="Infinity" prefHeight="42" styleClass="input-field" />
            </VBox>
            <VBox spacing="6" alignment="BOTTOM_RIGHT">
                <Button fx:id="btnGuardarTop" text="Guardar Cambios" styleClass="btn-primary" />
            </VBox>
        </HBox>

        <TableView fx:id="gradesTable"
                   styleClass="cursos-table"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colEstudiante"   text="ESTUDIANTE"     />
                <TableColumn fx:id="colMatricula"    text="ID MATRÍCULA"   />
                <TableColumn fx:id="colCalifActual"  text="CALIFICACIÓN"   />
                <TableColumn fx:id="colNuevaCalif"   text="NUEVA NOTA"     />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="No hay estudiantes registrados." styleClass="cursos-placeholder" />
            </placeholder>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="12">
            <padding>
                <Insets top="16" right="40" bottom="32" left="40"/>
            </padding>
            <Button fx:id="btnCancelar" text="Cancelar" styleClass="btn-secondary" />
            <Button fx:id="btnGuardarBottom" text="Guardar Cambios" styleClass="btn-primary" />
        </HBox>
    </VBox>
</VBox>
