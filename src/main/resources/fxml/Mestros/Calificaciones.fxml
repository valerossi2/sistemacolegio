<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox fx:id="root"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.edugrade.controller.GradesController"
      styleClass="cursos-root"
      spacing="0"
      maxWidth="Infinity"
      maxHeight="Infinity"
      stylesheets="@../../css/base.css,@../../css/Cursos.css,@../../css/Calificaciones.css">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <HBox fx:id="topBar" styleClass="grades-topbar" spacing="16" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Buscar estudiante..." styleClass="grades-search" HBox.hgrow="ALWAYS" />
        <Button fx:id="btnGuardarTop" text="Guardar Cambios" styleClass="grades-btn" />
    </HBox>

    <VBox fx:id="gradesCard" styleClass="grades-card" VBox.vgrow="ALWAYS" spacing="0">
        <Text fx:id="pageTitle" text="Gestión de Calificaciones - 5to E" styleClass="grades-title" />

        <HBox fx:id="filterBox" spacing="16" alignment="CENTER_LEFT">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblPeriodo" text="Periodo" styleClass="grades-label" />
                <ComboBox fx:id="comboPeriodo" styleClass="grades-combo" maxWidth="Infinity" prefHeight="42" />
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTipoEval" text="Tipo de Evaluación" styleClass="grades-label" />
                <ComboBox fx:id="comboTipoEval" styleClass="grades-combo" maxWidth="Infinity" prefHeight="42" />
            </VBox>
        </HBox>

        <TableView fx:id="gradesTable"
                   styleClass="grades-table"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colEstudiante"   text="ESTUDIANTE"     />
                <TableColumn fx:id="colMatricula"    text="MATRÍCULA"      />
                <TableColumn fx:id="colCalifActual"  text="NOTA ACTUAL"    />
                <TableColumn fx:id="colNuevaCalif"   text="NUEVA NOTA"     />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="No hay estudiantes registrados." styleClass="cursos-placeholder" />
            </placeholder>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button fx:id="btnCancelar" text="Cancelar" styleClass="grades-btn-secondary" />
            <Button fx:id="btnGuardarBottom" text="Guardar Cambios" styleClass="grades-btn" />
        </HBox>
    </VBox>
</VBox>
