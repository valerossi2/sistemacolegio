<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.edugrade.controller.GradesController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
            stylesheets="@../../css/Calificaciones.css">

    <VBox spacing="0">
        <padding>
            <Insets top="32" right="40" bottom="40" left="40"/>
        </padding>

        <!-- PAGE TITLE ROW -->
        <HBox alignment="BOTTOM_LEFT" spacing="0">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Text fx:id="pageTitle" text="Gestión de Calificaciones - 5to E"
                      style="-fx-font-family: 'Plus Jakarta Sans'; -fx-font-weight: bold; -fx-font-size: 24px;" />
                <Text fx:id="pageSubtitle" text="Ingresa y gestiona las calificaciones de los estudiantes."
                      style="-fx-font-family: 'Plus Jakarta Sans'; -fx-font-size: 14px;" />
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnGuardarTop" text="Guardar Cambios" />
            </HBox>
        </HBox>

        <Region prefHeight="24"/>

        <!-- FILTERS -->
        <GridPane hgap="24" vgap="0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0" spacing="6">
                <Label text="Periodo" />
                <ComboBox fx:id="comboPeriodo" maxWidth="Infinity" prefHeight="42" />
            </VBox>

            <VBox GridPane.columnIndex="1" spacing="6">
                <Label text="Tipo de Evaluación" />
                <ComboBox fx:id="comboTipoEval" maxWidth="Infinity" prefHeight="42" />
            </VBox>
        </GridPane>

        <Region prefHeight="24"/>

        <!-- GRADES TABLE -->
        <TableView fx:id="gradesTable" prefHeight="320" minHeight="220"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colEstudiante"   text="ESTUDIANTE"          prefWidth="300" minWidth="240"/>
                <TableColumn fx:id="colMatricula"    text="ID MATRÍCULA"        prefWidth="180" minWidth="140"/>
                <TableColumn fx:id="colCalifActual"  text="CALIFICACIÓN ACTUAL" prefWidth="200" minWidth="160"/>
                <TableColumn fx:id="colNuevaCalif"   text="NUEVA CALIFICACIÓN"  prefWidth="200" minWidth="160"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="No hay estudiantes registrados." />
            </placeholder>
        </TableView>

        <Region prefHeight="20"/>

        <!-- BOTTOM ACTION BUTTONS -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button fx:id="btnCancelar" text="Cancelar" />
            <Button fx:id="btnGuardarBottom" text="Guardar Cambios" />
        </HBox>

    </VBox>
</ScrollPane>
